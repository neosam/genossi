# OIDC Configuration Example
# Copy this file to .env and fill in your OIDC provider details

# Database configuration
DATABASE_URL=sqlite:genossi.db
SERVER_ADDRESS=0.0.0.0:3000

# Base URL for Swagger UI
BASE_PATH=http://localhost:3000/

# OIDC Configuration (required when using --features oidc)
# The full URL where this application is hosted (must match callback URL in OIDC provider)
APP_URL=http://localhost:3000

# OIDC Provider issuer URL (e.g., https://accounts.google.com, https://login.microsoftonline.com/{tenant}/v2.0)
ISSUER=https://your-oidc-provider.com

# Client ID from your OIDC provider
CLIENT_ID=your-client-id

# Client Secret from your OIDC provider (optional for public clients)
CLIENT_SECRET=your-client-secret

# Build and run with OIDC:
# cargo build --no-default-features --features oidc
# cargo run --no-default-features --features oidc